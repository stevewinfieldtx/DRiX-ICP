# --- Core ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database / Queue ---
# On Railway, add the PostgreSQL + Redis plugins; they inject these automatically.
# Ensure the DB URL uses the psycopg scheme:
DATABASE_URL=postgresql+psycopg://fitscore:fitscore@localhost:5432/fitscore
REDIS_URL=redis://localhost:6379/0

# --- LLM (rubric generation + Tier 1 scoring) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Tier 2 enrichment + Section 8 firmographics (Apollo: firmographics,
#     technographics, departmental headcounts, funding) ---
APOLLO_API_KEY=

# --- Section 8 web search (news) ---
SERPER_API_KEY=

# --- Section 8 own-site capture (managed scraping; falls back to direct httpx) ---
FIRECRAWL_API_KEY=

# --- Own-site polite scraper (httpx fallback path) ---
SCRAPER_USER_AGENT=FitScoreBot/1.0 (+https://yourdomain.example/botinfo)
SCRAPER_RESPECT_ROBOTS=true
SCRAPER_MAX_PAGES_PER_DOMAIN=8
SCRAPER_REQUEST_DELAY_SECONDS=2.0

# --- Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LIGHT=
STRIPE_PRICE_DEEP=
