# --- Core ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database / Queue (Railway injects these in prod) ---
DATABASE_URL=postgresql+psycopg://fitscore:fitscore@localhost:5432/fitscore
REDIS_URL=redis://localhost:6379/0

# --- LLM (rubric generation + Tier 1 scoring) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Tier 2 enrichment (official APIs only) ---
CLEARBIT_API_KEY=
BUILTWITH_API_KEY=

# --- Section 8 compliant data sources (licensed APIs; leave blank to disable) ---
NEWS_API_KEY=
CRUNCHBASE_API_KEY=
# Provider used for LinkedIn-style firmographics via official/licensed API (NOT scraping)
PEOPLE_DATA_API_KEY=

# --- Speculative own-site scraper (first-party, polite) ---
SCRAPER_USER_AGENT=FitScoreBot/1.0 (+https://yourdomain.example/botinfo)
SCRAPER_RESPECT_ROBOTS=true
SCRAPER_MAX_PAGES_PER_DOMAIN=8
SCRAPER_REQUEST_DELAY_SECONDS=2.0

# --- Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LIGHT=
STRIPE_PRICE_DEEP=
